// ─── CURRICULUM DOMAIN ───────────────────────────────────────────────────────

model Curriculum {
  id        Int    @id @default(autoincrement())
  name      String
  countryId Int    @map("country_id")

  // Relations
  country Country @relation(fields: [countryId], references: [id])
  grades  Grade[]

  @@map("curriculums")
}
