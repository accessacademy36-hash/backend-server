// ─── USER DOMAIN ─────────────────────────────────────────────────────────────

enum Role {
  admin
  student
  teacher
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  password  String
  countryId Int      @map("country_id")
  timezone  String
  role      Role
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  country               Country              @relation(fields: [countryId], references: [id])
  teacherProfile        TeacherProfile?
  studentProfile        StudentProfile?
  paymentRequests       PaymentRequest[]     @relation("StudentPayments")
  reviewedPayments      PaymentRequest[]     @relation("ReviewedPayments")
  subscriptions         Subscription[]
  bookingRequests       BookingRequest[]
  teacherAvailability   TeacherAvailability[]
  teacherUnavailable    TeacherUnavailable[]
  teachingAssignments   TeachingAssignment[]
  lectureDelaysApproved LectureDelay[]       @relation("ApprovedDelays")
  lectureAttendances    LectureAttendance[]
  reviews               Review[]

  @@map("users")
}
